[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = []

[project.scripts]
"{{ project_slug }}" = "{{ package_name }}:main"

[dependency-groups]
dev = [
    "black>=25.0",
    "pre-commit>=4.0",
    "pytest>=8.0",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
addopts = "-q"
pythonpath = ["src"]
testpaths = ["tests"]

[tool.black]
line-length = 88
target-version = ["py{{ python_version | replace('.', '') }}"]
